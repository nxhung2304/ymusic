# YMusic Environment Variables
# Copy this file to .env and fill in your actual values
# ⚠️ NEVER commit .env to version control - it contains sensitive data!

# Firebase Configuration (from Firebase Console > Project Settings)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

# Firebase API Keys (from Firebase Console > Build > Authentication > Web API Key)
# Get these from: https://console.firebase.google.com/ > Project Settings > Service Accounts > Web API Key
FIREBASE_API_KEY_IOS=your-ios-api-key
FIREBASE_API_KEY_ANDROID=your-android-api-key
FIREBASE_API_KEY_WEB=your-web-api-key

# Firebase App IDs (from google-services.json or GoogleService-Info.plist)
FIREBASE_APP_ID_IOS=your-ios-app-id
FIREBASE_APP_ID_ANDROID=your-android-app-id
FIREBASE_APP_ID_WEB=your-web-app-id

# Firebase Messaging Sender ID (from google-services.json)
FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id

# Google Cloud & YouTube API
YOUTUBE_API_KEY=your-youtube-api-key
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# App Configuration
APP_ENV=development
LOG_LEVEL=debug

# Feature Flags
ENABLE_ANALYTICS=false
ENABLE_CRASH_REPORTING=false
